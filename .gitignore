# Python bytecode cache — auto-generated, never commit these
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
.venv/
venv/
env/

# Environment variables (secrets)
.env

# SQLite database file — contains real user data, never commit
data/
*.db

# OS files
.DS_Store
Thumbs.db

# VS Code environment settings (local config)
.vscode/

# User uploaded or generated temporary media files (videos/audios)
*.mp4
*.avi
*.mov
*.wav
*.mp3
temp_workout.mp4

